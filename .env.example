# انسخ هذا الملف إلى .env محلياً
# على السيرفر (Hostinger VPS / Node): ضع نفس القيم في .env قبل build:hostinger وتشغيل PM2

# ── Firebase (عام — يُضمَّن في bundle المتصفح) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── الموقع ──
# محلي:
# VITE_SITE_URL=http://localhost:8080
# إنتاج:
VITE_SITE_URL=https://top1markting.com

# ── اختياري ──
VITE_GTM_ID=
VITE_GSC_VERIFICATION=

# ── سيرفر فقط (لا تستخدم VITE_ — لا تُعرض في المتصفح) ──
IMGBB_API_KEY=

# ── Node (Hostinger VPS) ──
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
