# انسخ إلى .env محلياً | وعلى Vercel أضف نفس المفاتيح في Project → Settings → Environment Variables

# ═══════════════════════════════════════════════════════════
# REQUIRED — بدونها الموقع أو النماذج/الـ Admin لا يعملان
# ═══════════════════════════════════════════════════════════

# Firebase Web (عميل + سيرفر) — تُضمَّن في bundle المتصفح (عامة حسب تصميم Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Measurement ID للـ Analytics (يمكن تركه فارغاً إذا عطّلت Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# رابط الموقع العام — canonical / sitemap / OG
# محلي: http://localhost:8080
VITE_SITE_URL=https://www.top1markting.com

# Service Account JSON في سطر واحد — سيرفر فقط — مطلوب لـ /api/leads
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# ═══════════════════════════════════════════════════════════
# RECOMMENDED على Vercel (إنتاج متعدد الـ instances)
# ═══════════════════════════════════════════════════════════

# Upstash Redis REST — rate limit موزّع لـ leads / upload / APIs
# بدونها: حد معدّل داخل الذاكرة لكل instance فقط
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════

VITE_GTM_ID=
VITE_GSC_VERIFICATION=

# بديل رفع الصور إن فشل Firebase Storage
IMGBB_API_KEY=

# ═══════════════════════════════════════════════════════════
# Hostinger / Node فقط (ليس مطلوباً على Vercel)
# ═══════════════════════════════════════════════════════════
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
