rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() &&
        userDoc().data.role == 'admin';
    }

    function isEditor() {
      return isSignedIn() &&
        userDoc().data.role in ['admin', 'editor'];
    }

    // User profiles — الإنشاء والصلاحيات بواسطة admin فقط
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isAdmin() &&
        request.resource.data.keys().hasOnly(['role', 'email', 'createdAt']) &&
        request.resource.data.role in ['admin', 'editor'];
      allow update: if isAdmin() || (
        isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.keys().hasOnly(['role', 'email', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    function isPublicContent() {
      return !('status' in resource.data) ||
        resource.data.status == null ||
        resource.data.status == 'published';
    }

    match /pages/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /services/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /portfolio/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /blog_posts/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /blog_categories/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /blog_tags/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /testimonials/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /pricing_plans/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /faqs/{docId} {
      allow read: if isPublicContent() || isEditor();
      allow write: if isEditor();
    }

    match /site_stats/{docId} {
      allow read: if isEditor() || isPublicContent();
      allow write: if isEditor();
    }

    match /media/{docId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /leads/{docId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'message', 'source', 'status', 'createdAt', 'updatedAt'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 0 &&
        request.resource.data.phone.size() <= 30 &&
        (!('email' in request.resource.data) ||
          (request.resource.data.email is string &&
            request.resource.data.email.size() > 0 &&
            request.resource.data.email.size() <= 254)) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000 &&
        request.resource.data.source is string &&
        request.resource.data.source.size() <= 64 &&
        request.resource.data.status == 'new';
      allow read, update, delete: if isEditor();
    }
  }
}
