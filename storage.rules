rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isEditor() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.contentType.matches('image/(jpeg|png|webp)') &&
        request.resource.size < 12 * 1024 * 1024;
    }

    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isEditor() && isImageUpload();
      allow delete: if isEditor();
      allow update: if isEditor() && isImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
